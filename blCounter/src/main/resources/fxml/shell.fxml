<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mjtrac.counter.fx.ShellController"
            stylesheets="@../css/counter.css">
    <left>
        <ScrollPane fitToWidth="true" styleClass="sidebar" hbarPolicy="NEVER">
            <VBox styleClass="sidebar" spacing="2">
                <Label fx:id="titleLabel" styleClass="sidebar-title" text="pbss Election Counter" wrapText="true"/>
                <Button text="Dashboard" styleClass="sidebar-link" onAction="#showDashboard"/>

                <VBox fx:id="countingSection" spacing="2">
                    <Label text="COUNTING" styleClass="sidebar-section-label"/>
                    <Button text="New Count" styleClass="sidebar-link" onAction="#showDashboard"/>
                    <Button text="Results" styleClass="sidebar-link" onAction="#showResults"/>
                </VBox>

                <VBox fx:id="viewerSection" spacing="2">
                    <Label text="VIEWER" styleClass="sidebar-section-label"/>
                    <Button text="Ballot Viewer" styleClass="sidebar-link" onAction="#showViewer"/>
                </VBox>

                <VBox fx:id="adminSection" spacing="2">
                    <Label text="ADMINISTRATION" styleClass="sidebar-section-label"/>
                    <Button text="Users" styleClass="sidebar-link" onAction="#showAdmin"/>
                </VBox>

                <VBox spacing="2">
                    <Label text="ACCOUNT" styleClass="sidebar-section-label"/>
                    <Button text="Change Password" styleClass="sidebar-link" onAction="#showAccount"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </left>
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="top-bar" spacing="16">
            <Label fx:id="breadcrumbLabel" styleClass="title-label" text="Dashboard" HBox.hgrow="ALWAYS"/>
            <Label fx:id="signedInAsLabel" style="-fx-font-size:12px;-fx-text-fill:#555;"/>
            <Button text="Sign out" onAction="#handleSignOut"/>
        </HBox>
    </top>
    <center>
        <StackPane fx:id="contentArea">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
        </StackPane>
    </center>
</BorderPane>
